# Generated by scripts/local-stack-up.sh
.env.sandbox

# Terraform
# .terraform.lock.hcl IS committed (HashiCorp best practice — pins provider
# hashes across envs + CI for reproducible `terraform init`).
**/.terraform/*
**/terraform.tfstate
**/terraform.tfstate.*
**/*.tfvars
**/*.tfvars.json
tfplan.bin

# Vercel
.vercel

# TypeScript
*.tsbuildinfo
next-env.d.ts

# Prisma
prisma/*.db
prisma/*.db-journal
prisma/*.db-shm
prisma/*.db-wal

# Local uploads (user-generated content)
public/uploads/*
# But keep the directory structure
!public/uploads/.gitkeep

